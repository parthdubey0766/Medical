# ============================================================
# PARTH'S MEDICAL CLINIC — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# For Vercel: add these in Project Settings → Environment Variables.
# NEVER commit .env.local to version control.
# ============================================================

# ┌──────────────────────────────────────────┐
# │  Firebase Client SDK (Public — browser)  │
# └──────────────────────────────────────────┘
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ┌──────────────────────────────────────────┐
# │  Firebase Admin SDK (Server — NEVER expose) │
# └──────────────────────────────────────────┘
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ┌──────────────────────────────────────────┐
# │  Resend (Email Service)                  │
# └──────────────────────────────────────────┘
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@parth06.app

# ┌──────────────────────────────────────────┐
# │  Twilio (SMS — optional)                 │
# └──────────────────────────────────────────┘
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ┌──────────────────────────────────────────┐
# │  reCAPTCHA v3 (optional)                 │
# └──────────────────────────────────────────┘
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-site-key
RECAPTCHA_SECRET_KEY=your-secret-key

# ┌──────────────────────────────────────────┐
# │  App Config                              │
# └──────────────────────────────────────────┘
NEXT_PUBLIC_SITE_URL=https://parth06.app
NEXT_PUBLIC_CLINIC_PHONE=+91-9876543210
NEXT_PUBLIC_CLINIC_EMAIL=clinic@parth06.app
NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210

# ┌──────────────────────────────────────────┐
# │  Admin Dashboard                         │
# └──────────────────────────────────────────┘
# Choose a STRONG password — this protects patient data!
ADMIN_PASSWORD=choose-a-strong-password-here

# ┌──────────────────────────────────────────┐
# │  Dev Mode                                │
# └──────────────────────────────────────────┘
# Set to "true" to use mock data instead of real Firebase.
# For Vercel production: do NOT set this, or set to "false".
USE_MOCK_DATA=true
